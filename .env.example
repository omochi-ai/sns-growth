# 自動投稿システム用の環境変数（実値は .env にコピーして記入。コミット禁止）

# --- Claude API（投稿文ジェネレータ T-002 用） ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Threads (Meta) 公式API（T-001 投稿用・無料） ---
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- X（当面 無料運用：API実投稿はしない。スケジューラ取込用エクスポートのみ） ---
# X_API_KEY=（D-002で課金承認された場合のみ）
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# --- 投稿設定 ---
POST_TIMES=07:00,12:00,20:00
TIMEZONE=Asia/Tokyo
DAILY_LIMIT_PER_PLATFORM=3
